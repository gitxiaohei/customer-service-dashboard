  "devDependencies": {
    "@lark-apaas/coding-presets": "^1.0.0",
    "@lark-apaas/coding-vite-preset": "^1.0.0",
    "@vercel/nft": "^0.29.2",
    "@types/express": "^5",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9",
    "eslint": "^9",
    "tsc-alias": "^1.8.15",
    "tsx": "^4",
    "typescript": "~5.9",
    "vite": "^8"
  }
}
